{
  "name": "boom-contact",
  "version": "0.1.0",
  "private": true,
  "description": "💥 boom.contact — Constat amiable numérique mondial",
  "scripts": {
    "dev": "concurrently \"tsx watch server/src/index.ts\" \"vite\"",
    "build": "vite build && npm run build:server",
    "build:server": "node build-server.mjs",
    "start": "node dist/server/index.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "build:client": "vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "capture:screenshots": "tsx scripts/capture-store-screenshots.ts",
    "check:claims": "tsx scripts/check-claims.ts",
    "quality:prestore": "npm run typecheck && npm run build && npm run test && npm run check:claims && npm run check:i18n",
    "check:i18n": "tsx scripts/check-i18n.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.85.0",
