    "@pdf-lib/fontkit": "1.1.1",
    "@sentry/node": "10.47.0",
    "@sentry/react": "10.47.0",
    "@tanstack/react-query": "5.67.1",
    "@trpc/client": "11.0.0",
    "@trpc/react-query": "11.0.0",
    "@trpc/server": "11.0.0",
    "bcryptjs": "3.0.3",
    "canvas": "3.2.3",
    "compression": "1.8.1",
