    "cors": "2.8.5",
    "drizzle-orm": "0.45.2",
    "express": "4.18.2",
    "express-rate-limit": "7.0.0",
    "form-data": "4.0.1",
    "helmet": "8.0.0",
    "i18next": "26.0.3",
    "i18next-browser-languagedetector": "8.2.1",
    "jsonwebtoken": "9.0.0",
    "morgan": "1.10.1",
    "pdf-lib": "1.17.1",
