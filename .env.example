# Database
DATABASE_URL=postgresql://user:password@localhost:5432/boom_contact

# Anthropic (OCR)
ANTHROPIC_API_KEY=sk-ant-...

# Auth
JWT_SECRET=your-super-secret-key-here

# App
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
# RAILWAY_PUBLIC_DOMAIN is set automatically by Railway — no need to set locally

# Email (Resend)
RESEND_API_KEY=re_...

# OpenAI Whisper (transcription vocale)
OPENAI_API_KEY=sk-proj-...

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_TAX_ENABLED=false

# ── Social Publishing ─────────────────────────────────────────
SOCIAL_SECRET=your-social-cron-secret
FB_PAGE_ACCESS_TOKEN=your-facebook-page-access-token
FB_PAGE_ID=your-facebook-page-id
IG_USER_ID=your-instagram-user-id
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
LINKEDIN_ACCESS_TOKEN=your-linkedin-access-token
LINKEDIN_ORG_ID=your-linkedin-org-id

# ── Admin ─────────────────────────────────────────────────────
ADMIN_BOOTSTRAP_SECRET=your-admin-bootstrap-secret
ADMIN_EMAIL=contact@boom.contact
ADMIN_PASSWORD=your-admin-password

# ── WIN WIN / Groupe NEO ──────────────────────────────────────
WINWIN_SECRET=your-winwin-secret
WINWIN_PARTNER_KEY=your-winwin-partner-key
NEO_COCKPIT_URL=https://cockpit.groupeneo.ch
NEO_COCKPIT_SECRET=your-neo-cockpit-secret
NEO_APP_URL=https://www.boom.contact
NEO_ALERT_PHONE=+41...

# ── Twilio (SMS alerts) ──────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM=+41...

# ── Google Maps ───────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=AIza...

# ── Puppeteer (sketch rendering) ─────────────────────────────
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ── Logging ───────────────────────────────────────────────────
LOG_DEBUG=false

# ── Analytics & Monitoring ────────────────────────────────────
# Sentry — error tracking (frontend + backend)
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_DSN_BACKEND=https://xxx@xxx.ingest.sentry.io/xxx

# PostHog — product analytics (frontend + backend)
VITE_POSTHOG_KEY=phc_xxx
VITE_POSTHOG_HOST=https://eu.i.posthog.com
POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://eu.i.posthog.com

# Google Analytics 4 — traffic analytics (frontend only)
VITE_GA4_ID=G-XXXXXXXXXX
