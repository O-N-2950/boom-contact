{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "jsx": "react-jsx",
    "customConditions": ["@zod/source"],
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["client/src", "server/src", "shared"]
}
