# keystore.properties.example — boom.contact (package contact.boom.app)
#
# Copier ce fichier en `android/keystore.properties` (gitignored, JAMAIS commité)
# OU définir les variables d'environnement équivalentes en CI.
#
# Priorité de résolution dans android/app/build.gradle :
#   1) variables d'environnement   2) ce fichier keystore.properties
#
# Variables d'environnement équivalentes :
#   KEYSTORE_PASSWORD  ->  storePassword
#   KEY_PASSWORD       ->  keyPassword
#   KEY_ALIAS          ->  keyAlias    (défaut: boom-contact)
#   KEYSTORE_FILE      ->  storeFile   (défaut: boom-contact-release.keystore)
#
# Aucune valeur par défaut de mot de passe n'existe : un build release SANS ces
# secrets échoue explicitement (fail-fast). Ne jamais committer de vraies valeurs.

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=boom-contact
storeFile=boom-contact-release.keystore
